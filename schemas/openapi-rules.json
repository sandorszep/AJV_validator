{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "paths": {
      "type": "object",
      "additionalProperties": {
        "allOf": [
          {
            "if": {
              "not": {
                "propertyNames": { "pattern": ".*(com\\.sap|\\$)" }
              }
            },
            "then": {
              "type": "object",
              "properties": {
                "get": { "$ref": "get-method" },
                "post": { "$ref": "post-method" },
                "patch": { "$ref": "patch-method" },
                "delete": { "$ref": "delete-method" }
              }
            }
          }
        ]
      }
    }
  },
  "required": ["paths"]
}
